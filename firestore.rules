rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to validate standard IDs
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Helper for category
    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name', 'allocatedBudget', 'spent', 'color', 'icon'])
        && data.id is string
        && data.name is string
        && data.name.size() <= 100
        && data.allocatedBudget is number
        && data.spent is number
        && data.color is string
        && data.icon is string;
    }

    // Helper for expense
    function isValidExpense(data) {
      return data.keys().hasAll(['id', 'categoryId', 'amount', 'description', 'date'])
        && data.id is string
        && data.categoryId is string
        && data.amount is number
        && data.description is string
        && data.description.size() <= 200
        && data.date is string;
    }

    // Helper for notification
    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'categoryId', 'categoryName', 'type', 'message', 'timestamp', 'isRead'])
        && data.id is string
        && data.categoryId is string
        && data.categoryName is string
        && data.type is string
        && (data.type == 'warning' || data.type == 'info' || data.type == 'critical' || data.type == 'normal')
        && data.message is string
        && data.timestamp is string
        && data.isRead is bool;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
